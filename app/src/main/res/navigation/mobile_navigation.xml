<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_note">

    <fragment
        android:id="@+id/nav_note"
        android:name="com.app.notesappandroidproject.fragments.NoteFragment"
        android:label="@string/menu_note"
        tools:layout="@layout/fragment_note">

        <action
            android:id="@+id/action_nav_note_to_note_detail"
            app:destination="@+id/nav_note_details"
            app:enterAnim="@anim/pull_in_right"
            app:exitAnim="@anim/push_out_left"
            app:popEnterAnim="@anim/pull_in_left"
            app:popExitAnim="@anim/push_out_right" />

    </fragment>

    <fragment
        android:id="@+id/nav_note_details"
        android:name="com.app.notesappandroidproject.fragments.NoteDetailFragment"
        tools:layout="@layout/fragment_note_detail" />

    <fragment
        android:id="@+id/nav_archive"
        android:name="com.app.notesappandroidproject.fragments.RecycleBinFragment"
        tools:layout="@layout/fragment_note" />


</navigation>