<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/bottomContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Status1 -->
        <LinearLayout
            android:id="@+id/statusBackground1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/accentRed"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statusType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="15dp"
                android:ellipsize="middle"
                android:fontFamily="@font/quicksand_bold"
                android:gravity="center_horizontal"
                android:letterSpacing="0.1"
                android:singleLine="true"
                android:text="@string/note"
                android:textAllCaps="true"
                android:textColor="@color/colorPrimary"
                android:textSize="11sp"
                tools:ignore="SmallSp" />

            <TextView
                android:id="@+id/statusContent"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="30dp"
                android:layout_marginEnd="30dp"
                android:ellipsize="middle"
                android:fontFamily="@font/quicksand_medium"
                android:gravity="center_horizontal"
                android:singleLine="true"
                android:text="@string/new_note"
                android:textColor="@color/colorPrimary"
                android:textSize="19sp" />

        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/statusShadow"
            android:layout_marginTop="-15dp">

            <!-- Status2 -->
            <LinearLayout
                android:id="@+id/statusBackground2"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="@color/accentRed"
                android:orientation="vertical" />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerHorizontal="true"
                            android:layout_marginBottom="65dp"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            card_view:cardBackgroundColor="@android:color/transparent"
                            card_view:cardCornerRadius="25dp"
                            card_view:cardElevation="3dp"
                            card_view:cardUseCompatPadding="true">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <com.github.mmin18.widget.RealtimeBlurView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_alignTop="@id/contentView"
                                    android:layout_alignBottom="@id/contentView"
                                    app:realtimeBlurRadius="100dp"
                                    app:realtimeDownsampleFactor="4"
                                    app:realtimeOverlayColor="#99FFFFFF" />

                                <!-- Content -->
                                <RelativeLayout
                                    android:id="@+id/contentView"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/view_card"
                                    android:nestedScrollingEnabled="false"
                                    android:overScrollMode="never"
                                    android:padding="10dp"
                                    android:scrollbars="none">

                                    <LinearLayout
                                        android:id="@+id/LL_1"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:background="?attr/selectableItemBackground"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:orientation="vertical"
                                        android:padding="18dp"
                                        android:paddingStart="25dp"
                                        android:paddingTop="10dp"
                                        android:paddingEnd="25dp"
                                        android:paddingBottom="10dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:ellipsize="end"
                                            android:maxLines="2"
                                            android:fontFamily="@font/quicksand_medium"
                                            android:textColor="@color/colorAccent"
                                            android:textSize="19sp"
                                            android:textStyle="bold"
                                            app:layout_constraintTop_toTopOf="parent"
                                            app:layout_constraintStart_toStartOf="parent"
                                            android:text="@string/title"/>

                                        <com.rengwuxian.materialedittext.MaterialEditText
                                            android:id="@+id/edt_title"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="11dp"
                                            android:ellipsize="end"
                                            android:hint="@string/title"
                                            android:paddingStart="13dp"
                                            android:paddingEnd="13dp"
                                            android:gravity="start"
                                            android:singleLine="true"
                                            android:fontFamily="@font/quicksand"
                                            android:textSize="19sp"
                                            app:met_floatingLabel="highlight"
                                            app:met_floatingLabelText="@string/title"
                                            app:met_floatingLabelTextColor="@color/colorAccent"
                                            app:met_primaryColor="@color/colorAccent"
                                            app:met_textColorHint="@color/alpha10_000000" />

                                        <TextView
                                            android:id="@+id/tv_content"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:ellipsize="end"
                                            android:maxLines="2"
                                            android:fontFamily="@font/quicksand_medium"
                                            android:textColor="@color/colorAccent"
                                            android:textSize="19sp"
                                            android:textStyle="bold"
                                            android:layout_marginTop="10dp"
                                            android:text="@string/content"/>

                                        <com.rengwuxian.materialedittext.MaterialEditText
                                            android:id="@+id/edt_content"
                                            android:layout_width="match_parent"
                                            android:layout_height="300dp"
                                            android:hint="@string/content"
                                            android:layout_marginTop="11dp"
                                            android:paddingStart="13dp"
                                            android:fontFamily="@font/quicksand"
                                            android:paddingEnd="13dp"
                                            android:gravity="start"
                                            android:textSize="19sp"
                                            android:scrollbars="vertical"
                                            android:isScrollContainer="true"
                                            app:backgroundTint="@android:color/white"
                                            android:inputType="textMultiLine"
                                            app:met_floatingLabel="highlight"
                                            app:met_floatingLabelText="@string/content"
                                            app:met_floatingLabelTextColor="@color/colorAccent"
                                            app:met_primaryColor="@color/colorAccent"
                                            app:met_textColor="@color/color_333333"
                                            app:met_textColorHint="@color/alpha10_000000" />

                                    </LinearLayout>

                                </RelativeLayout>

                            </RelativeLayout>

                        </androidx.cardview.widget.CardView>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <TextView
                        android:id="@+id/tv_time_update"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:singleLine="true"
                        android:layout_gravity="end"
                        android:layout_marginEnd="29dp"
                        android:fontFamily="@font/quicksand_medium"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12dp"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:text="last update: 2020.07.29 21 44" />

                    <TextView
                        android:id="@+id/tv_time_create"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:singleLine="true"
                        android:fontFamily="@font/quicksand_medium"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12dp"
                        android:layout_gravity="end"
                        android:layout_marginEnd="29dp"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:text="Created: 2020.07.29 21 44" />

                </LinearLayout>

        </RelativeLayout>

        <View
            android:id="@+id/statusShadow"
            android:layout_width="match_parent"
            android:layout_height="15dp"
            android:background="@drawable/shadow"
            android:layout_below="@id/statusBackground1" />

        <!-- Back -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/statusBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/accentRed"
            android:contentDescription="@null"
            android:src="@drawable/ic_arrow_back"
            app:borderWidth="0dp"
            app:elevation="0dp"
            app:fabSize="mini"
            app:tint="@android:color/white" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_marginBottom="15dp"
            android:layout_marginEnd="15dp"
            android:animateLayoutChanges="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/white"
            android:visibility="visible"
            app:backgroundTint="@color/colorAccent"
            app:fabSize="normal"
            app:srcCompat="@drawable/save" />

    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>